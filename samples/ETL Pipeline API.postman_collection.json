  "item": [
    {
      "name": "Create Pipeline",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"pipelineId\": \"sales_etl_001\",\r\n  \"pipelineName\": \"Daily Sales ETL\",\r\n  \"tenantId\": \"tenant_123\",\r\n  \"description\": \"Filter and aggregate sales data\",\r\n  \"source\": {\r\n    \"type\": \"csv\",\r\n    \"config\": {\r\n      \"file_path\": \"src/main/resources/sample-data/sales.csv\",\r\n      \"delimiter\": \",\",\r\n      \"has_header\": true,\r\n      \"encoding\": \"utf-8\"\r\n    }\r\n  },\r\n  \"transformations\": [\r\n    {\r\n      \"type\": \"filter\",\r\n      \"config\": { \"condition\": \"quantity > 0\" }\r\n    },\r\n    {\r\n      \"type\": \"map\",\r\n      \"config\": {\r\n        \"operations\": {\r\n          \"total_amount\": \"quantity * price\"\r\n        }\r\n      }\r\n    },\r\n    {\r\n      \"type\": \"aggregate\",\r\n      \"config\": {\r\n        \"group_by\": [\"product_id\"],\r\n        \"aggregations\": {\r\n          \"total_quantity\": \"SUM(quantity)\",\r\n          \"total_revenue\": \"SUM(total_amount)\",\r\n          \"transaction_count\": \"COUNT()\"\r\n        }\r\n      }\r\n    }\r\n  ],\r\n  \"destination\": {\r\n    \"type\": \"database\",\r\n    \"config\": {\r\n      \"table\": \"daily_sales_summary\",\r\n      \"write_mode\": \"append\",\r\n      \"batch_size\": 1000\r\n    }\r\n  }\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:8080/api/v1/pipelines",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "v1",
            "pipelines"
          ]
        }
      },
      "response": []
    },
